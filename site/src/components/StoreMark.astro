---
interface Props {
  channel: 'steam' | 'eshop';
  class?: string;
}

const { channel, class: className } = Astro.props;
---
<span class:list={['store-mark', `is-${channel}`, className]} aria-hidden="true" data-store-mark={channel}>
  {channel === 'steam' ? (
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.1" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="15.8" cy="7.2" r="3.4" />
      <circle cx="6.1" cy="16.8" r="2.6" />
      <path d="m8.35 15.5 4.75-4.05" />
      <path d="m3.65 15.7-2.15-.9" />
      <path d="m8.3 17.7 4.15 1.8a5.5 5.5 0 0 0 7.25-2.85l1.55-3.55" />
      <circle cx="15.8" cy="7.2" r="1.35" fill="currentColor" stroke="none" />
    </svg>
  ) : (
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M7 8V6a5 5 0 0 1 10 0v2" />
      <rect x="3" y="8" width="18" height="13" rx="2" />
      <path d="M12 9.5v10" />
      <circle cx="8.2" cy="13" r="1.4" />
      <circle cx="15.8" cy="16.5" r="1.4" />
    </svg>
  )}
</span>
