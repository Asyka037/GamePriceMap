---
interface Props {
  active?: 'home' | 'steam' | 'nintendo' | null;
  /** Home: search hidden until the hero search scrolls away. */
  dock?: boolean;
}
const { active = null, dock = false } = Astro.props;
---
<header class="site-header">
  <div class="wrap header-inner">
    <a class="logo" href="/" aria-label="GamePriceMap home">
      <span class="mark" aria-hidden="true">
        <img src="/brand/gamepricemap-logo-96.png" alt="" width="96" height="96" decoding="async" fetchpriority="high" />
      </span>
      <span class="logo-word">Game<em>PriceMap</em></span>
    </a>

    <div class:list={['header-search', { dock }]} id="dockSearch">
      <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      <input type="text" id="siteSearch" placeholder="Search games…" aria-label="Search games" autocomplete="off" />
      <kbd>/</kbd>
      <div class="search-results" id="searchResults" hidden></div>
    </div>

    <nav class="main-nav">
      <div class="nav-item"><a class:list={['nav-link', { active: active === 'home' }]} href="/">Home</a></div>
      <div class="nav-item">
        <span class:list={['nav-link', { active: active === 'steam' }]} tabindex="0">Steam
          <svg viewBox="0 0 24 24" fill="none" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
        </span>
        <div class="dropdown">
          <a href="/steam/deals">Deals</a>
          <a href="/steam/regional-pricing">Regional pricing</a>
          <div class="sep"></div>
          <a href="/free-games">PC free games</a>
          <a href="/new-releases">PC new releases</a>
        </div>
      </div>
      <div class="nav-item">
        <span class:list={['nav-link', { active: active === 'nintendo' }]} tabindex="0">Nintendo
          <svg viewBox="0 0 24 24" fill="none" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
        </span>
        <div class="dropdown">
          <a href="/switch/deals">Deals</a>
          <a href="/switch/regional-pricing">Regional pricing</a>
          <div class="sep"></div>
          <a href="/new-releases">Nintendo Switch new releases</a>
        </div>
      </div>
    </nav>

    <div class="header-actions">
      <span class="region-btn" title="More currencies later — all conversions shown in USD today">
        <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
        USD
      </span>
    </div>
  </div>
</header>

<script>
  import MiniSearch from 'minisearch';

  let mini: MiniSearch | null = null;
  let loading: Promise<MiniSearch> | null = null;

  function ensureIndex(): Promise<MiniSearch> {
    if (mini) return Promise.resolve(mini);
    loading ??= fetch('/search-index.json')
      .then((res) => res.json())
      .then((docs) => {
        mini = new MiniSearch({ fields: ['title'], storeFields: ['title', 'slug'], searchOptions: { prefix: true, fuzzy: 0.2 } });
        mini.addAll(docs);
        return mini;
      });
    return loading;
  }

  /** Reusable search wiring: input + its own visible results dropdown. */
  function attach(input: HTMLInputElement | null, resultsEl: HTMLElement | null) {
    if (!input || !resultsEl) return;
    const render = (hits: Array<{ slug: string; title: string }>) => {
      if (hits.length === 0) { resultsEl.hidden = true; resultsEl.innerHTML = ''; return; }
      resultsEl.innerHTML = hits.slice(0, 8).map((h) => {
        const a = document.createElement('a');
        a.href = `/game/${h.slug}`;
        a.textContent = h.title;
        return a.outerHTML;
      }).join('');
      resultsEl.hidden = false;
    };
    input.addEventListener('focus', () => { ensureIndex(); }, { once: true });
    input.addEventListener('input', async () => {
      const q = input.value.trim();
      if (!q) { render([]); return; }
      const m = await ensureIndex();
      if (input.value.trim() !== q) return; // 输入已变化，丢弃过期结果
      render(m.search(q) as never[]);
    });
    document.addEventListener('click', (e) => {
      if (!resultsEl.contains(e.target as Node) && e.target !== input) render([]);
    });
    input.addEventListener('keydown', (e) => { if (e.key === 'Escape') render([]); });
  }

  attach(document.getElementById('siteSearch') as HTMLInputElement, document.getElementById('searchResults'));
  attach(document.getElementById('heroSearch') as HTMLInputElement, document.getElementById('heroSearchResults'));

  document.addEventListener('keydown', (e) => {
    if (e.key === '/' && !(document.activeElement instanceof HTMLInputElement)) {
      e.preventDefault();
      const hero = document.getElementById('heroSearch') as HTMLInputElement | null;
      const site = document.getElementById('siteSearch') as HTMLInputElement | null;
      (hero && hero.offsetParent !== null ? hero : site)?.focus();
    }
  });

  // Home-only: dock the header search once the hero search scrolls away.
  const dockEl = document.getElementById('dockSearch');
  const heroSearch = document.querySelector('.hero-search');
  if (dockEl?.classList.contains('dock') && heroSearch) {
    const check = () => dockEl.classList.toggle('show', heroSearch.getBoundingClientRect().bottom < 70);
    window.addEventListener('scroll', check, { passive: true });
    setInterval(check, 300);
    check();
  }
</script>
