---
import { WORLD, mapRegions } from '../lib/mapgrid.mjs';
import { fmtUsd, fmtMoney } from '../lib/derive.mjs';

interface Props {
  snapshot: any;             // §4.2 snapshot
  channel: 'steam' | 'eshop';
  compact?: boolean;         // decorative, non-interactive variant
}
const { snapshot, channel, compact = false } = Astro.props;
const { baseline, regions } = mapRegions(snapshot?.regions);
const base = regions.find((r) => r.cc === baseline);
const cheapest = [...regions].sort((a, b) => a.usd - b.usd)[0];
const summary = cheapest && base
  ? `Pixel world map of regional prices. Baseline ${base.cc} at ${fmtUsd(base.usd)}; cheapest is ${cheapest.cc} at ${fmtUsd(cheapest.usd)} (${Math.abs(cheapest.pctVsBaseline)}% below). Full data in the table below.`
  : 'Pixel world map of regional prices.';

const S = 10; // svg units per cell
const W = WORLD.cols * S;
const H = WORLD.rows * S;
const rect = (r: number, c: number, len: number) =>
  ({ x: c * S + 0.6, y: r * S + 0.6, width: len * S - 1.2, height: S - 1.2 });
const tip = (r: any) =>
  r.cc === baseline
    ? `${r.cc} · ${fmtMoney(r.local, r.currency)} — baseline`
    : `${r.cc} · ${fmtMoney(r.local, r.currency)} ≈ ${fmtUsd(r.usd)} (${r.pctVsBaseline > 0 ? '+' : '−'}${Math.abs(r.pctVsBaseline)}% vs ${baseline})`;
---
<div class:list={['pixel-map-wrap', { compact }]}>
  <svg
    class="pixel-map-svg"
    viewBox={`0 0 ${W} ${H}`}
    role="group"
    aria-label={summary}
    data-baseline-x={base ? base.centroid.x * S : null}
    data-baseline-y={base ? base.centroid.y * S : null}
  >
    {WORLD.land.map(([r, c, len]: number[]) => (
      <rect class="wm-land" {...rect(r, c, len)} rx="1.4" />
    ))}
    {regions.map((rg) => (
      <g
        class:list={['wm-cc', rg.cls]}
        tabindex={compact ? undefined : 0}
        role={compact ? undefined : 'button'}
        aria-label={compact ? undefined : tip(rg)}
        data-tip={compact ? undefined : tip(rg)}
        data-target={compact ? undefined : `region-${channel}-${rg.cc}`}
        data-cx={rg.centroid.x * S}
        data-cy={rg.centroid.y * S}
        data-dir={rg.dir}
      >
        {rg.runs.map(([r, c, len]: number[]) => <rect {...rect(r, c, len)} rx="1.4" />)}
      </g>
    ))}
    {base && (
      <text class="wm-base-label" x={base.centroid.x * S} y={base.centroid.y * S - 8} text-anchor="middle">{base.cc}</text>
    )}
    <line class="wm-compare-line" x1="0" y1="0" x2="0" y2="0" visibility="hidden" />
    <circle class="wm-compare-dot" r="4" visibility="hidden" />
  </svg>
  {!compact && (
    <div class="map-legend">
      <span><i class="map-key wm-cheaper-2"></i>cheaper than {baseline}</span>
      <span><i class="map-key wm-baseline"></i>{baseline} baseline</span>
      <span><i class="map-key wm-pricier-2"></i>pricier than {baseline}</span>
      <span style="color: var(--text-3);">deep shade = 30%+ gap · hover a country to compare</span>
    </div>
  )}
</div>

<script>
  if (!(window as any).__pixelMapInit) {
    (window as any).__pixelMapInit = true;
    const tipEl = document.createElement('div');
    tipEl.className = 'map-tooltip';
    tipEl.hidden = true;
    document.body.appendChild(tipEl);

    for (const svg of document.querySelectorAll<SVGSVGElement>('.pixel-map-svg')) {
      const line = svg.querySelector<SVGLineElement>('.wm-compare-line');
      const dot = svg.querySelector<SVGCircleElement>('.wm-compare-dot');
      const bx = Number(svg.dataset.baselineX);
      const by = Number(svg.dataset.baselineY);

      const show = (g: SVGGElement) => {
        tipEl.textContent = g.dataset.tip ?? '';
        tipEl.hidden = false;
        const r = g.getBoundingClientRect();
        tipEl.style.left = `${Math.max(8, r.left + r.width / 2 + window.scrollX - tipEl.offsetWidth / 2)}px`;
        tipEl.style.top = `${r.top + window.scrollY - tipEl.offsetHeight - 10}px`;
        if (line && dot && Number.isFinite(bx) && g.dataset.dir !== 'baseline') {
          line.setAttribute('x1', g.dataset.cx!);
          line.setAttribute('y1', g.dataset.cy!);
          line.setAttribute('x2', String(bx));
          line.setAttribute('y2', String(by));
          line.dataset.dir = g.dataset.dir;
          line.removeAttribute('visibility');
          dot.setAttribute('cx', String(bx));
          dot.setAttribute('cy', String(by));
          dot.removeAttribute('visibility');
        }
      };
      const hide = () => {
        tipEl.hidden = true;
        line?.setAttribute('visibility', 'hidden');
        dot?.setAttribute('visibility', 'hidden');
      };

      for (const g of svg.querySelectorAll<SVGGElement>('.wm-cc[data-tip]')) {
        g.addEventListener('mouseenter', () => show(g));
        g.addEventListener('focus', () => show(g));
        g.addEventListener('mouseleave', hide);
        g.addEventListener('blur', hide);
        g.addEventListener('click', () => {
          const row = document.getElementById(g.dataset.target ?? '');
          if (!row) return;
          row.scrollIntoView({ behavior: 'smooth', block: 'center' });
          row.classList.remove('row-flash');
          void row.offsetWidth;
          row.classList.add('row-flash');
        });
        g.addEventListener('keydown', (e) => {
          if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); (g as any).click(); }
        });
      }
    }
  }
</script>
