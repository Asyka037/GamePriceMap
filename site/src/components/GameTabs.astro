---
interface Props { slug: string; current: 'overview' | 'regional' | 'history' }
const { slug, current } = Astro.props;
const tabs = [
  { id: 'overview', label: 'Overview', href: `/game/${slug}` },
  { id: 'regional', label: 'Regional prices', href: `/game/${slug}/regional-prices` },
  { id: 'history', label: 'Price history', href: `/game/${slug}/price-history` },
];
---
<div class="tab-nav-scroll">
  <nav class="tab-nav" aria-label="Game sections">
    {tabs.map((t) => (
      <a class:list={[{ on: t.id === current }]} href={t.href} aria-current={t.id === current ? 'page' : undefined}>{t.label}</a>
    ))}
  </nav>
</div>
