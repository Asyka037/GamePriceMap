---
import NoteBox from './NoteBox.astro';
import RegionalGameCard from './RegionalGameCard.astro';
import { regionalListingCards } from '../lib/derive.mjs';

interface Props {
  bundles: any[];
  channel: 'steam' | 'eshop';
}
const { bundles, channel } = Astro.props;
const cards = regionalListingCards(bundles, channel);
---
<div class="regional-card-grid" data-regional-hub={channel}>
  {cards.map((card) => <RegionalGameCard card={card} />)}
</div>

<NoteBox>
  Store list prices converted at daily exchange rates — not checkout totals.
  Cross-region purchases depend on your account, payment method and platform
  rules; taxes and card fees can change the final amount.
</NoteBox>
