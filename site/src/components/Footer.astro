---
interface Props { updatedAt?: string | null }
const { updatedAt = null } = Astro.props;
const stamp = updatedAt ? new Date(updatedAt).toUTCString().replace(':00 GMT', ' UTC') : null;
---
<footer class="site-footer">
  <div class="wrap footer-inner">
    <div>
      <div class="logo" style="margin-bottom: 12px;">
        <span class="mark"><svg viewBox="0 0 24 24" fill="none" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.83z"/><circle cx="7" cy="7" r="1.6" fill="#fff" stroke="none"/></svg></span>
        <span class="logo-word">Game<em>PriceMap</em></span>
      </div>
      <p class="footer-note">
        Track game prices across Steam, Nintendo eShop and Xbox. Compare stores
        and regions, explore verified price history, spot meaningful discounts,
        and find free games and upcoming releases — all in one place.
      </p>
    </div>
    <div>
      <h4>Steam</h4>
      <a href="/steam/deals">Deals</a>
      <a href="/steam/regional-pricing">Regional pricing</a>
      <a href="/free-games">PC free games</a>
    </div>
    <div>
      <h4>Nintendo</h4>
      <a href="/switch/deals">Deals</a>
      <a href="/switch/regional-pricing">Regional pricing</a>
    </div>
    <div>
      <h4>Topics</h4>
      <a href="/new-releases">PC &amp; Switch new releases</a>
      <a href="/free-games">Epic &amp; Steam free games</a>
    </div>
    <div>
      <h4>GamePriceMap</h4>
      <a href="/about">About &amp; data sources</a>
      <a href="/status">Data status</a>
    </div>
  </div>
  <div class="wrap footer-bottom">
    <span>© 2026 GamePriceMap — not affiliated with Valve or Nintendo</span>
    {stamp && <span>Data updated {stamp}</span>}
  </div>
</footer>
