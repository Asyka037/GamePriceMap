---
import Layout from '../../layouts/Layout.astro';
import RegionalHub from '../../components/RegionalHub.astro';
import { catalog, gameBundle } from '../../lib/data.mjs';

const bundles = catalog().map((g: any) => gameBundle(g.slug));
---
<Layout
  title="Steam Regional Prices: Cheapest Regions & Deals | GamePriceMap"
  description="Compare Steam game prices across global regions. Track regional discounts and rank the best store savings instantly."
  active="steam"
>
  <div class="page-head wrap">
    <div class="breadcrumb"><a href="/">Home</a><span>/</span>Steam<span>/</span>Regional pricing</div>
    <h1>Steam regional pricing</h1>
    <p class="regional-hub-intro">Browse Steam-supported games by the biggest savings between their cheapest and most expensive regions.</p>
  </div>
  <div class="wrap" style="padding-bottom: 24px;">
    <RegionalHub bundles={bundles} channel="steam" />
  </div>
</Layout>
