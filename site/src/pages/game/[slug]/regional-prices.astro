---
import Layout from '../../../layouts/Layout.astro';
import GameHero from '../../../components/GameHero.astro';
import GameTabs from '../../../components/GameTabs.astro';
import NoteBox from '../../../components/NoteBox.astro';
import PixelWorldMap from '../../../components/PixelWorldMap.astro';
import RegionalComparisonTable from '../../../components/RegionalComparisonTable.astro';
import { catalog, gameBundle } from '../../../lib/data.mjs';
import { fmtUsd, multiRegionalPriceSummary, regionalPriceSources } from '../../../lib/derive.mjs';
import { regionalGameSeo } from '../../../lib/seo.mjs';

export function getStaticPaths() {
  return catalog().map((g: { slug: string }) => ({ params: { slug: g.slug } }));
}

const { slug } = Astro.params;
const bundle = gameBundle(slug!);
const { game } = bundle;

const sources = regionalPriceSources(bundle).map((source: any) => ({
  ...source,
  offers: source.key === 'steam' ? (bundle.steamOffers?.offers ?? []) : (source.offers ?? []),
}));
const summary = multiRegionalPriceSummary(game.title, sources);
const configuredMapSource = sources.find((source: any) => source.key === game.primaryRegionalChannel);
const mapSource = configuredMapSource ?? sources[0] ?? null;
const seo = mapSource
  ? regionalGameSeo(game.title, mapSource.key, mapSource.snapshot)
  : {
      title: `${game.title} Region Prices | GamePriceMap`,
      description: `Compare regional game prices and store discounts for ${game.title}.`,
    };
---
<Layout
  title={seo.title}
  description={seo.description}
>
  <GameHero bundle={bundle} />
  <div class="wrap">
    <GameTabs slug={slug!} current="regional" />

    <section class="regional-page-section">
      {summary ? (
        <>
          <h2 class="regional-page-title">{game.title} Cheapest Regions</h2>
          <p class="regional-summary" aria-label={summary.text}>
            <span>Compare {game.title} {summary.platformListLabel} prices globally. Cheapest:</span>{' '}
            <strong class="regional-summary-fact is-cheapest">
              {summary.cheapest.countryName}
              <span class="regional-summary-value"> ({fmtUsd(summary.cheapest.usd)}).</span>
            </strong>{' '}
            <span>Most expensive:</span>{' '}
            <strong class="regional-summary-fact is-priciest">
              {summary.mostExpensive.countryName}
              <span class="regional-summary-value"> ({fmtUsd(summary.mostExpensive.usd)}).</span>
            </strong>{' '}
            {summary.priceSpreadPct > 0 ? (
              <>
                <span>Save up to</span>{' '}
                <strong class="regional-summary-fact is-saving">
                  <span class="regional-summary-value">{summary.savingsPct}%</span>
                </strong>{' '}
                <span>{sources.length > 1 ? 'across tracked stores and regions.' : 'via regional pricing.'}</span>
              </>
            ) : <span>Tracked regional prices are currently equal.</span>}
          </p>

          {mapSource && (
            <section class="regional-primary-map" aria-labelledby="regional-primary-map-title">
              <h3 id="regional-primary-map-title" class="regional-primary-map-label">
                {mapSource.label} Region Savings Map
              </h3>
              <PixelWorldMap snapshot={mapSource.snapshot} channel={mapSource.key as 'steam' | 'eshop'} />
            </section>
          )}

          <div class="regional-platform-stack">
            {sources.map((source: any) => (
              <RegionalComparisonTable gameTitle={game.title} source={source} />
            ))}
          </div>
        </>
      ) : <p style="color:var(--text-2); font-weight:600;">No regional data tracked for this game yet.</p>}

      <NoteBox>
        These are store list prices with exchange-rate estimates — not checkout
        totals. Cross-region purchases depend on your account, payment method
        and platform rules, and may not be possible; taxes and card fees can
        change the final amount. Anomalously outdated regional prices are
        filtered out automatically.
      </NoteBox>
    </section>
  </div>
</Layout>
