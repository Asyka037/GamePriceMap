---
import Layout from '../../../layouts/Layout.astro';
import GameHero from '../../../components/GameHero.astro';
import GameTabs from '../../../components/GameTabs.astro';
import NoteBox from '../../../components/NoteBox.astro';
import { catalog, gameBundle, sourceHealth } from '../../../lib/data.mjs';
import { fmtUsd } from '../../../lib/derive.mjs';
import { multiStepChartModel } from '../../../lib/chart.mjs';

export function getStaticPaths() {
  return catalog().map((g: { slug: string }) => ({ params: { slug: g.slug } }));
}

const { slug } = Astro.params;
const bundle = gameBundle(slug!);
const { game } = bundle;
const atlLabels: Record<string, string> = { pc: 'PC (any store, US)', 'eshop-us': 'eShop US', 'eshop-eu': 'eShop EU (converted)', 'xbox-us': 'Xbox Store US' };
const seedLabels: Record<string, string> = {
  self: 'observed by our tracker',
  cheapshark: 'all-time record via CheapShark',
  'eshop-eu': 'UK-shop lowest via Nintendo index',
};
const historyEvents = bundle.history?.events ?? [];
const events = [...historyEvents].reverse();

// 趋势图：美区自观测阶梯线；末端 = 该源 lastSuccessAt（最后一次确认价格的时刻），
// 不是"今天"——抓取停摆时线就停在那里，不假装数据仍新鲜。
const health = sourceHealth().sources ?? {};
const TRACKING_SINCE = '2026-07-08';
const channelDefs = [
  { id: 'steam', label: 'Steam · US', color: 'var(--teal)', lineStyle: 'solid', dash: '', marker: 'square', source: 'steam-regional', tracked: !!bundle.steam },
  { id: 'eshop', label: 'eShop · US', color: 'var(--red)', lineStyle: 'dash', dash: '10 6', marker: 'circle', source: 'eshop-regional', tracked: !!bundle.eshop },
  { id: 'xbox', label: 'Xbox · US', color: 'var(--text-2)', lineStyle: 'dot', dash: '3 6', marker: 'diamond', source: 'xbox-us', tracked: !!bundle.xbox, fallbackSince: '2026-07-12' },
].filter((channel) => channel.tracked);

const chart = multiStepChartModel(historyEvents, {
  channels: channelDefs.map((channel) => ({
    id: channel.id,
    endDate: health[channel.source]?.lastSuccessAt ?? null,
  })),
});
const seriesById = new Map(chart.series.map((series) => [series.id, series]));
const channels = channelDefs.map((channel) => {
  const series = seriesById.get(channel.id)!;
  return {
    ...channel,
    series,
    since: series.firstDate ?? channel.fallbackSince ?? TRACKING_SINCE,
    checkedAt: health[channel.source]?.lastSuccessAt?.slice(0, 10) ?? null,
  };
});

function seriesStatus(channel: typeof channels[number]) {
  if (channel.series.state === 'changes') return `${channel.series.dots.length} recorded price points`;
  if (channel.series.state === 'confirmed-flat') return `unchanged since ${channel.series.firstDate}`;
  if (channel.series.state === 'point') return `tracking since ${channel.since}`;
  return 'awaiting first observation';
}

const chartDescription = channels.map((channel) => {
  if (channel.series.lastUsd == null) return `${channel.label}: awaiting first observation`;
  return `${channel.label}: ${fmtUsd(channel.series.lastUsd)}, observed from ${channel.series.firstDate} through ${channel.series.endDate}`;
}).join('; ');
---
<Layout
  title={`${game.title} Price History & All-Time Low Tracker | GamePriceMap`}
  description={`Find the all-time low and complete price history across store channels. Track active discounts and grab the best deal today for ${game.title}.`}
>
  <GameHero bundle={bundle} />
  <div class="wrap">
    <GameTabs slug={slug!} current="history" />

    <section style="padding: 24px 0 8px;">
      <div class="panel trend-panel">
        <h3 id="trend-title">
          <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linejoin="round" stroke-linecap="round"><polyline points="3 17 8 17 8 11 13 11 13 6 21 6"/></svg>
          US price trend
        </h3>
        <figure class="trend-figure">
          <figcaption class="trend-legend" id="trend-legend">
            {channels.map((channel) => (
              <div class="trend-key" data-channel={channel.id} data-state={channel.series.state}>
                <span class="trend-key-main">
                  <i
                    class:list={['trend-swatch', `is-${channel.lineStyle}`, `marker-${channel.marker}`]}
                    style={`color:${channel.color};`}
                    aria-hidden="true"
                  ></i>
                  <strong>{channel.label}</strong>
                  {channel.series.lastUsd != null && <span class="trend-now mono">{fmtUsd(channel.series.lastUsd)}</span>}
                </span>
                <small>
                  {channel.checkedAt ? <>checked <time datetime={channel.checkedAt}>{channel.checkedAt}</time></> : 'not checked yet'}
                  <span aria-hidden="true"> · </span>{seriesStatus(channel)}
                </small>
              </div>
            ))}
          </figcaption>
          {chart.hasObservations ? (
            <div class="trend-chart-scroll" role="region" aria-label={`${game.title} multi-store US price chart`} tabindex="0">
                <svg
                  class="trend-svg"
                  data-history-chart
                  viewBox={`0 0 ${chart.w} ${chart.h}`}
                  role="img"
                  aria-labelledby="trend-title"
                  aria-describedby="trend-chart-desc trend-legend"
                >
                  <desc id="trend-chart-desc">{chartDescription}</desc>
                  {chart.yTicks.map((tick) => (
                    <>
                      <line x1={chart.plot!.x} y1={tick.y} x2={chart.plot!.x + chart.plot!.w} y2={tick.y} class="trend-grid-line" />
                      <text x={chart.plot!.x - 8} y={tick.y + 5} class="trend-tick" text-anchor="end">{tick.label}</text>
                    </>
                  ))}
                  {chart.xTicks.map((tick) => (
                    <text x={tick.x} y={chart.h - 7} class="trend-tick" text-anchor={tick.anchor}>{tick.label}</text>
                  ))}
                  {channels.map((channel) => channel.series.path && (
                    <g data-channel={channel.id}>
                      <path
                        data-series-line
                        d={channel.series.path}
                        class="trend-line"
                        style={`stroke:${channel.color};stroke-dasharray:${channel.dash || 'none'};`}
                        vector-effect="non-scaling-stroke"
                      />
                      {channel.series.endPoint && (
                        <g>
                          <title>{channel.label} confirmed through {channel.series.endPoint.d} at {fmtUsd(channel.series.endPoint.usd)}</title>
                          <line
                            x1={channel.series.endPoint.x}
                            y1={channel.series.endPoint.y - 6}
                            x2={channel.series.endPoint.x}
                            y2={channel.series.endPoint.y + 6}
                            class="trend-end-cap"
                            style={`stroke:${channel.color};`}
                            vector-effect="non-scaling-stroke"
                          />
                        </g>
                      )}
                    </g>
                  ))}
                  {channels.map((channel) => channel.series.dots.map((point) => (
                    <g data-channel={channel.id}>
                      {channel.marker === 'circle' ? (
                        <circle cx={point.x} cy={point.y} r="5" class="trend-dot" style={`fill:${channel.color};`} vector-effect="non-scaling-stroke">
                          <title>{channel.label}: {point.d} — {fmtUsd(point.usd)}{point.pct ? ` (−${point.pct}%)` : ''}</title>
                        </circle>
                      ) : channel.marker === 'diamond' ? (
                        <polygon points={`${point.x},${point.y - 6} ${point.x + 6},${point.y} ${point.x},${point.y + 6} ${point.x - 6},${point.y}`} class="trend-dot" style={`fill:${channel.color};`} vector-effect="non-scaling-stroke">
                          <title>{channel.label}: {point.d} — {fmtUsd(point.usd)}{point.pct ? ` (−${point.pct}%)` : ''}</title>
                        </polygon>
                      ) : (
                        <rect x={point.x - 5} y={point.y - 5} width="10" height="10" class="trend-dot" style={`fill:${channel.color};`} vector-effect="non-scaling-stroke">
                          <title>{channel.label}: {point.d} — {fmtUsd(point.usd)}{point.pct ? ` (−${point.pct}%)` : ''}</title>
                        </rect>
                      )}
                    </g>
                  )))}
                </svg>
            </div>
          ) : (
            <p class="trend-empty">Automatic tracking is active; the first US price observation has not been recorded yet.</p>
          )}
        </figure>
        <p class="trend-note">Steam and eShop are checked daily; Xbox is checked weekly. Flat segments mean later checks found no price change, and each line stops at that store’s last successful check.</p>
      </div>

      <div class="detail-cols history-detail-cols">
        <div class="panel">
          <h3>
            <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
            All-time lows
          </h3>
          {Object.entries(bundle.history?.atl ?? {}).map(([key, atl]: [string, any]) => (
            <div class="kv">
              <span class="k">{atlLabels[key] ?? key}</span>
              <span class="v mono" style="color:var(--gold);">{fmtUsd(atl.usd)}</span>
            </div>
          ))}
          <p style="font-size:12.5px; color:var(--text-3); font-weight:600; margin-top:10px;">
            {Object.entries(bundle.history?.atl ?? {}).map(([key, atl]: [string, any]) => (
              <span style="display:block;">{atlLabels[key] ?? key}: {seedLabels[atl.seed] ?? atl.seed}{atl.date ? ` (${atl.date})` : ''}</span>
            ))}
          </p>
        </div>

        <div class="panel">
          <h3>Price change log</h3>
          {events.length > 0 ? (
            <table class="region-full" style="border:none; box-shadow:none;">
              <thead><tr><th>Date</th><th>Channel</th><th>US price</th><th>Discount</th></tr></thead>
              <tbody>
                {events.map((e: any) => (
                  <tr>
                    <td class="mono">{e.d}</td>
                    <td>{e.ch}</td>
                    <td class="mono" style="font-weight:700;">{fmtUsd(e.usd)}</td>
                    <td>{e.pct ? <span class="chip-off">−{e.pct}%</span> : <span style="color:var(--text-3);">—</span>}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          ) : (
            <p style="color:var(--text-2); font-weight:600;">No price changes recorded yet — tracking started recently.</p>
          )}
        </div>
      </div>

      <NoteBox>
        Automatic checks do not add duplicate rows. The log records a new event
        only when the US price or discount changes, so a quiet stretch means the
        checked price stayed the same. Tracking began 2026-07-08; earlier lows
        come from external records where noted.
      </NoteBox>
    </section>
  </div>
</Layout>

<style>
  .trend-figure { margin: 12px 0 0; min-width: 0; }
  .trend-legend {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 10px;
    margin-bottom: 12px;
  }
  .trend-key {
    min-width: 0;
    padding: 9px 11px;
    background: var(--surface-2);
    border: 2px solid #D8CEB1;
    border-radius: var(--radius);
  }
  .trend-key-main { display: flex; align-items: center; gap: 8px; min-width: 0; }
  .trend-key-main strong { color: var(--ink); font-size: 13.5px; white-space: nowrap; }
  .trend-key small { display: block; margin: 3px 0 0 34px; color: var(--text-2); font-size: 10.5px; font-weight: 700; }
  .trend-key time { font-family: var(--font-mono); }
  .trend-now { margin-left: auto; color: var(--ink); font-weight: 700; }
  .trend-swatch { position: relative; display: inline-block; width: 26px; height: 3px; flex: 0 0 26px; background: currentColor; }
  .trend-swatch.is-dash { background: repeating-linear-gradient(90deg, currentColor 0 8px, transparent 8px 12px); }
  .trend-swatch.is-dot { background: repeating-linear-gradient(90deg, currentColor 0 3px, transparent 3px 7px); }
  .trend-swatch::after {
    content: ''; position: absolute; left: 10px; top: -3px; width: 7px; height: 7px;
    background: currentColor; border: 1.5px solid var(--ink);
  }
  .trend-swatch.marker-circle::after { border-radius: 50%; }
  .trend-swatch.marker-diamond::after { transform: rotate(45deg); }
  .trend-chart-scroll {
    width: 100%; max-width: 100%; min-width: 0; overflow-x: auto;
    padding: 0 4px 4px 0;
  }
  .trend-chart-scroll:focus-visible { outline-offset: 2px; }
  .history-detail-cols {
    grid-template-columns: 340px minmax(0, 1fr);
    margin-top: 18px;
  }
  .history-detail-cols > .panel { min-width: 0; }
  @media (max-width: 1024px) {
    .history-detail-cols { grid-template-columns: minmax(0, 1fr); }
    .history-detail-cols .region-full { table-layout: fixed; }
  }
  .trend-svg {
    width: 100%;
    min-width: 680px;
    height: auto;
    display: block;
    background: #fff;
    border: 2.5px solid var(--ink);
    box-shadow: var(--shadow-sm);
  }
  .trend-grid-line { stroke: var(--ink); stroke-opacity: 0.14; stroke-width: 1; stroke-dasharray: 3 4; }
  .trend-tick { font-family: var(--font-mono); font-size: 12px; font-weight: 600; fill: var(--text-2); }
  .trend-line { fill: none; stroke-width: 3; stroke-linejoin: round; }
  .trend-end-cap { stroke-width: 3; }
  .trend-dot { stroke: var(--ink); stroke-width: 2; shape-rendering: crispEdges; }
  .trend-empty {
    border: 2.5px dashed var(--ink);
    padding: 22px 16px;
    font-size: 13px;
    font-weight: 600;
    color: var(--text-2);
    text-align: center;
  }
  .trend-note {
    margin-top: 10px;
    font-size: 12.5px;
    font-weight: 600;
    color: var(--text-3);
  }
  @media (max-width: 560px) {
    .trend-legend { grid-template-columns: 1fr; }
    .trend-key small { margin-left: 0; }
    .trend-svg { min-width: 620px; }
  }
</style>
