---
import ReleaseCalendarPage from '../../components/ReleaseCalendarPage.astro';
import { calendar } from '../../lib/data.mjs';

export function getStaticPaths() {
  return Object.keys(calendar().months).map((month) => ({ params: { month } }));
}

const { month } = Astro.params;
---
<ReleaseCalendarPage month={month!} />
