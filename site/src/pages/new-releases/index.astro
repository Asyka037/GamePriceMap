---
import ReleaseCalendarPage from '../../components/ReleaseCalendarPage.astro';
import { calendar } from '../../lib/data.mjs';

const current = new Date().toISOString().slice(0, 7);
const months = Object.keys(calendar().months).filter((m) => m >= current);
const target = months[0] ?? Object.keys(calendar().months).at(-1) ?? null;
---
{target ? <ReleaseCalendarPage month={target} canonicalPath={`/new-releases/${target}/`} /> : <p>No upcoming releases are available yet.</p>}
