---
import Layout from '../layouts/Layout.astro';
import NoteBox from '../components/NoteBox.astro';
import fs from 'node:fs';
import path from 'node:path';
import { fileURLToPath } from 'node:url';
import { formatUtcStamp, freshnessState } from '../lib/freshness.mjs';

const ROOT = path.join(path.dirname(fileURLToPath(import.meta.url)), '..', '..', '..');
const health = JSON.parse(fs.readFileSync(path.join(ROOT, 'data', 'health.json'), 'utf8'));

const labels: Record<string, string> = {
  rates: 'Exchange rates',
  'steam-regional': 'Steam regional prices',
  'steam-offers': 'Steam editions and add-ons',
  'eshop-regional': 'eShop regional prices',
  'xbox-us': 'Xbox Store prices (US POC)',
  'deals-steam': 'Steam deals feed',
  'deals-eshop': 'eShop deals feed',
  'deals-stores': 'Multi-store deals feed',
  'free-games': 'Free games feed',
  calendar: 'Release calendar',
  meta: 'Game metadata',
};
const cadence: Record<string, number> = {
  rates: 26, 'steam-regional': 26, 'eshop-regional': 26,
  'steam-offers': 8 * 24,
  'xbox-us': 8 * 24,
  'deals-steam': 26, 'deals-eshop': 26, 'deals-stores': 26, 'free-games': 26,
  calendar: 8 * 24, meta: 8 * 24,
};
const now = Date.now();
const rows = Object.entries(health.sources).map(([key, stamp]) => {
  const budget = cadence[key] ?? 26;
  const rawStamp = typeof stamp === 'string' ? stamp : null;
  return {
    label: labels[key] ?? key,
    rawStamp,
    stamp: formatUtcStamp(rawStamp),
    budget,
    state: freshnessState(rawStamp, budget, now),
  };
});
---
<Layout
  title="Data status — GamePriceMap"
  description="Freshness of every GamePriceMap data source: regional prices, deal feeds, calendar and metadata."
>
  <div class="page-head wrap">
    <div class="breadcrumb"><a href="/">Home</a><span>/</span>Status</div>
    <h1>Data status</h1>
    <p>Tracking {health.games} games. Last-success timestamps use UTC; freshness is recalculated in your browser against each source's daily or weekly cadence.</p>
  </div>

  <div class="wrap" style="padding-bottom: 24px;">
    <table class="region-full" style="max-width: 720px;">
      <thead><tr><th>Source</th><th>Last success (UTC)</th><th>State</th></tr></thead>
      <tbody>
        {rows.map((r) => (
          <tr data-status-row data-last-success={r.rawStamp ?? ''} data-budget-hours={r.budget}>
            <td style="font-weight:800;">{r.label}</td>
            <td class="mono">
              {r.rawStamp ? <time datetime={r.rawStamp}>{r.stamp}</time> : r.stamp}
            </td>
            <td>
              <span class="b-chip status-state" data-status-state={r.state}>{r.state.toUpperCase()}</span>
            </td>
          </tr>
        ))}
      </tbody>
    </table>

    <NoteBox>
      Every scrape passes a validation gate before landing: prices must be
      positive, discounts in range, currencies covered by current exchange rates and region
      coverage stable. A failed gate keeps the previous good data, so a stale
      source here means its upstream is unreachable — not that numbers are wrong.
    </NoteBox>
  </div>

  <script>
    import { freshnessState } from '../lib/freshness.mjs';

    const refreshStatusStates = () => {
      const now = Date.now();
      for (const row of document.querySelectorAll<HTMLElement>('[data-status-row]')) {
        const state = freshnessState(
          row.dataset.lastSuccess || null,
          Number(row.dataset.budgetHours),
          now,
        );
        const badge = row.querySelector<HTMLElement>('[data-status-state]');
        if (!badge) continue;
        badge.dataset.statusState = state;
        badge.textContent = state.toUpperCase();
      }
    };

    refreshStatusStates();
    window.setInterval(refreshStatusStates, 60_000);
    window.addEventListener('pageshow', refreshStatusStates);
    document.addEventListener('visibilitychange', () => {
      if (document.visibilityState === 'visible') refreshStatusStates();
    });
  </script>
</Layout>

<style>
  .status-state[data-status-state='fresh'] { background: var(--green-bg); }
  .status-state[data-status-state='stale'] { background: var(--gold-bg); }
  .status-state[data-status-state='down'] { background: var(--red-bg); }
</style>
